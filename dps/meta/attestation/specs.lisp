;;;; dps/meta/attestation/specs.lisp
;;;;
;;;; FiveAM attestation specs for dps-meta generated output.
;;;; These run AGAINST the generated files in a test checkout, not against
;;;; the generator internals.  The generator is correct when all specs pass.
;;;;
;;;; Execution:
;;;;   (ql:quickload :dps-meta-test)
;;;;   (fiveam:run! 'dps.meta.attestation:all)
;;;;
;;;; BDD rule: every spec here was written before the corresponding
;;;; generator function.  Do not add implementation before adding a spec.

(defpackage #:dps.meta.attestation
  (:use #:cl #:fiveam)
  (:export #:all))

(in-package #:dps.meta.attestation)

;;; ---------------------------------------------------------------------------
;;; Test suite root
;;; ---------------------------------------------------------------------------

(def-suite all
  :description "dps-meta generated-output attestation specs")

;;; ---------------------------------------------------------------------------
;;; Helpers
;;; ---------------------------------------------------------------------------

(defun test-checkout-path ()
  "Return the path of the test checkout directory.
   Set DPS_META_TEST_CHECKOUT env var to override; defaults to a temp dir
   populated by the BATS integration tests."
  (or (uiop:getenv "DPS_META_TEST_CHECKOUT")
      (error "DPS_META_TEST_CHECKOUT not set — run via BATS integration suite")))

(defun generated-file (relative-path)
  "Return an absolute pathname for RELATIVE-PATH under the test checkout."
  (merge-pathnames relative-path
                   (uiop:ensure-directory-pathname (test-checkout-path))))

(defun file-exists-p* (relative-path)
  "True if the generated file at RELATIVE-PATH exists."
  (uiop:file-exists-p (generated-file relative-path)))

(defun file-contains-p (relative-path substring)
  "True if the generated file at RELATIVE-PATH contains SUBSTRING."
  (let ((content (uiop:read-file-string (generated-file relative-path))))
    (search substring content)))

(defun yaml-key-present-p (relative-path key)
  "Crude but zero-dependency check: key appears on its own line in the YAML file."
  (file-contains-p relative-path (concatenate 'string key ":")))

;;; ---------------------------------------------------------------------------
;;; Suite: common governance files (all repo types)
;;; ---------------------------------------------------------------------------

(def-suite governance
  :description "Governance files generated for every repo type"
  :in all)

(in-suite governance)

(test claude-md-exists
  "CLAUDE.md must be generated"
  (is (file-exists-p* "CLAUDE.md")))

(test claude-md-has-spdx
  "CLAUDE.md must carry the BSD-2-Clause SPDX identifier"
  (is (file-contains-p "CLAUDE.md" "SPDX-License-Identifier: BSD-2-Clause")))

(test contributing-exists
  "CONTRIBUTING.md must be generated"
  (is (file-exists-p* "CONTRIBUTING.md")))

(test security-exists
  "SECURITY.md must be generated"
  (is (file-exists-p* "SECURITY.md")))

(test code-of-conduct-exists
  "CODE_OF_CONDUCT.md must be generated"
  (is (file-exists-p* "CODE_OF_CONDUCT.md")))

(test support-exists
  "SUPPORT.md must be generated"
  (is (file-exists-p* "SUPPORT.md")))

(test codeowners-exists
  ".github/CODEOWNERS must be generated"
  (is (file-exists-p* ".github/CODEOWNERS")))

(test changelog-stub-exists
  "CHANGELOG.md must be generated"
  (is (file-exists-p* "CHANGELOG.md")))

