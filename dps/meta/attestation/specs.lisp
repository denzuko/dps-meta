;;; ---------------------------------------------------------------------------
;;; Suite: SLSA Rego gate self-check
;;; ---------------------------------------------------------------------------

(def-suite slsa-gate-self-check
  :description "The generated policy/slsa.rego passes OPA syntax check"
  :in all)

(in-suite slsa-gate-self-check)

(test slsa-rego-opa-check
  "policy/slsa.rego must pass `opa check`"
  (let* ((rego-path (namestring (generated-file "policy/slsa.rego")))
         (result (uiop:run-program
                   (list "opa" "check" rego-path)
                   :output :string
                   :error-output :string
                   :ignore-error-status t)))
    ;; opa check exits 0 on success; non-zero on parse/compile error
    (is (string= "" result)
        "opa check produced output (errors): ~A" result)))
